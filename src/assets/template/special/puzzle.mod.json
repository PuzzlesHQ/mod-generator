{
  "formatVersion": 3,
  "display-name": "${p_name}",
  "id": "${p_id}",
  "version": "${p_version}",
  "description": "${p_desc}",
  "authors": [
    ${p_authors}
  ],
  "can-load-on": {
    "client": true,
    "server": true
  },

  "meta": {
    "icon": "${p_id}:icons/icon.png"
  },

  "entrypoints": {
    "client-postInit": "${p_group}.ClientExampleMod",
    "client-init": "${p_group}.ClientExampleMod",
    "client-preInit": "${p_group}.ClientExampleMod",

    "preInit": "${p_group}.PreInitExampleMod",
    "init": "${p_group}.InitExampleMod",
    "postInit": "${p_group}.PostInitExampleMod",

    "server-init": "${p_group}.ServerExampleMod"
  },

  // Comments are supported in here, just ignore the error your code editor may display
  "mixins": [
    "${p_id}.common.mixins.json",
    {
      "config": "${p_id}.client.mixins.json",
      "environment": "client"
    },
    {
      "config": "${p_id}.server.mixins.json",
      "environment": "server"
    }
  ],

  "depends": {
    "cosmic-reach": ">=0.5.7-alpha",
    "puzzle-loader-cosmic": ">=1.5.2-alpha",
    "puzzle-loader-core": ">=1.3.4-alpha",
    "cosmic-api": ">=1.3.6-0.5.7"
  },

  "access-writers": [
    "${p_id}.manipulator"
  ],

  "interface-injectors": [
    "${p_id}.inject"
  ]
}