{
  "formatVersion": 3,
  "display-name": "${p_name}",
  "id": "${p_id}",
  "version": "${p_version}",
  "description": "${p_desc}",
  "authors": [
    ${p_authors}
  ],
  "can-load-on": {
    "client": true,
    "server": true
  },

  "meta": {
    "icon": "${p_id}:icons/icon.png"
  },

  "entrypoints": {
    "client-postInit": "${p_group}.Client{{ mod_class_name }}",
    "client-init": "${p_group}.Client{{ mod_class_name }}",
    "client-preInit": "${p_group}.Client{{ mod_class_name }}",

    "init": "${p_group}.Init{{ mod_class_name }}",
    "server-init": "${p_group}.Server{{ mod_class_name }}"
  },

  {{ #mixins }}
  "mixins": [
    "${p_id}.common.mixins.json",
    {
      "config": "${p_id}.client.mixins.json",
      "environment": "client"
    },
    {
      "config": "${p_id}.server.mixins.json",
      "environment": "server"
    }
  ],
  {{ /mixins }}

  "depends": {
    "cosmic-reach": ">={{ cosmic_reach_version }}",
    "puzzle-loader-cosmic": ">={{ puzzle_loader_cosmic_version }}",
    "puzzle-loader-core": ">={{ puzzle_loader_core_version }}"
  },

  {{ #manipulators }}
  "access-writers": [
    "${p_id}.manipulator"
  ],
  {{ /manipulators }}

  {{ #injects }}
  "interface-injectors": [
    "${p_id}.inject"
  ]
  {{ /injects }}
}